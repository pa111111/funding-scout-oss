# funding-scout config. Скопируй в .env и подставь свои значения.
# .env в git НЕ коммитится (см. .gitignore).

# === Database ===
# Локально (default): SQLite в data/funding-scout.db
# DATABASE_URL=sqlite:///data/funding-scout.db
#
# На VPS: Postgres
DATABASE_URL=postgresql+psycopg://funding_scout:CHANGEME@localhost:5432/funding_scout

# === Logging ===
LOG_LEVEL=INFO

# === Telegram (для daily-report и watchdog) ===
# Создай нового бота через @BotFather (НЕ используй hedge-bot токен!)
FUNDING_SCOUT_TELEGRAM_BOT_TOKEN=
FUNDING_SCOUT_TELEGRAM_CHAT_ID=

# === Connector overrides (опционально, для тестов) ===
# HYPERLIQUID_API=https://api.hyperliquid.xyz
# LIGHTER_API=https://mainnet.zklighter.elliot.ai
